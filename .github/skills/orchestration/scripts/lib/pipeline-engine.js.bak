'use strict';

const path = require('path');
const fs   = require('fs');

const { preRead }             = require('./pre-reads');
const { getMutation, normalizeDocPath, handleWorktreeCreated, handleWorktreeRemoved } = require('./mutations');
const { validateTransition }  = require('./validator');
const { resolveNextAction, resolveIsolationMode }   = require('./resolver');
const { SCHEMA_VERSION }      = require('./constants');

// ─── Helpers ────────────────────────────────────────────────────────────────

function deepClone(obj) {
  return JSON.parse(JSON.stringify(obj));
}

/**
 * Extract the major version number from a config version string.
 * @param {string} configVersion - e.g., "5.0"
 * @returns {number} e.g., 5
 */
function extractConfigMajor(configVersion) {
  return parseInt(String(configVersion).split('.')[0], 10);
}

/**
 * Extract the version number from a state schema string.
 * @param {string} schemaVersion - e.g., "orchestration-state-v5"
 * @returns {number} e.g., 5
 */
function extractStateMajor(schemaVersion) {
  const match = String(schemaVersion).match(/v(\d+)$/);
  return match ? parseInt(match[1], 10) : 0;
}

/**
 * Check that config and state versions are compatible (same major version).
 * @param {Object} config - merged config object (has config.version — e.g., "5.0")
 * @param {Object} state  - parsed state object (has state.$schema — e.g., "orchestration-state-v5")
 * @returns {{ compatible: boolean, configVersion: string, stateVersion: string }}
 */
function checkVersionCompatibility(config, state) {
  const configMajor = extractConfigMajor(config.version);
  const stateMajor  = extractStateMajor(state.$schema);
  return {
    compatible: configMajor === stateMajor,
    configVersion: String(config.version),
    stateVersion: String(state.$schema),
  };
}

/**
 * Walk up from startDir to find the nearest directory containing .git/.
 * Uses fs.statSync to check for .git directory existence at each level.
 * Stops when path.dirname(current) === current (filesystem root reached).
 *
 * @param {string} startDir - absolute path to start from
 * @returns {string|null} absolute path to repo root, or null if not found
 */
function findRepoRoot(startDir) {
  let current = path.resolve(startDir);
  while (true) {
    try {
      const gitPath = path.join(current, '.git');
      const stat = fs.statSync(gitPath);
      if (stat.isDirectory()) return current;
    } catch (e) {
      // .git not found at this level — continue walking up
    }
    const parent = path.dirname(current);
    if (parent === current) return null; // reached filesystem root
    current = parent;
  }
}

/**
 * Determine whether worktree creation should be attempted after a mutation.
 * Returns true only when ALL of these are satisfied:
 *   1. proposedState.pipeline.source_control exists
 *   2. proposedState.pipeline.source_control.worktree_path === null
 *   3. proposedState.pipeline.current_tier !== 'planning'
 *   4. resolveIsolationMode(proposedState, config) === 'worktree'
 *   5. If config.source_control.branch_from === 'ask', then branch_from_choice !== null
 *
 * @param {Object} proposedState - state after primary mutation applied
 * @param {Object} config - merged orchestration config
 * @returns {boolean}
 */
function shouldCreateWorktree(proposedState, config) {
  const sc = proposedState.pipeline.source_control;
  if (!sc) return false;
  if (sc.worktree_path !== null) return false;
  if (proposedState.pipeline.current_tier === 'planning') return false;
  if (resolveIsolationMode(proposedState, config) !== 'worktree') return false;
  if (config.source_control.branch_from === 'ask' && sc.branch_from_choice === null) return false;
  return true;
}

/**
 * Determine whether worktree removal should be attempted after a mutation.
 * Returns true when EITHER:
 *   a. event === 'source_control_cleanup_set' AND cleanup_choice === 'remove'
 *   b. event === 'final_approved' AND config.source_control.cleanup === 'on_completion'
 * AND in both cases: worktree_path !== null
 *
 * @param {string} event - the current pipeline event name
 * @param {Object} proposedState - state after primary mutation applied
 * @param {Object} config - merged orchestration config
 * @returns {boolean}
 */
function shouldRemoveWorktree(event, proposedState, config) {
  const sc = proposedState.pipeline.source_control;
  if (!sc || sc.worktree_path === null) return false;

  if (event === 'source_control_cleanup_set' && sc.cleanup_choice === 'remove') return true;
  if (event === 'final_approved' && config.source_control.cleanup === 'on_completion') return true;

  return false;
}

/**
 * Compute the arguments needed to create a worktree.
 * @param {string} projectDir - absolute path to project directory
 * @param {Object} proposedState - post-mutation state
 * @param {Object} config - merged config
 * @param {Object} io - IO abstraction (for getDefaultBranch, getCurrentBranch, formatBranchName)
 * @returns {{ repoRoot: string, worktreePath: string, branchName: string, startPoint: string }}
 */
function computeWorktreeArgs(projectDir, proposedState, config, io) {
  const repoRoot = findRepoRoot(projectDir);

  const branchFromValue = proposedState.pipeline.source_control.branch_from_choice
                          ?? config.source_control.branch_from;
  const startPoint = (branchFromValue === 'default')
    ? io.getDefaultBranch(repoRoot)
    : io.getCurrentBranch(repoRoot);

  const branchName = io.formatBranchName(config.source_control.branch_prefix, path.basename(projectDir));
  const worktreePath = path.resolve(repoRoot, config.source_control.worktree_path, path.basename(projectDir));

  return { repoRoot, worktreePath, branchName, startPoint };
}

// ─── scaffoldInitialState ───────────────────────────────────────────────────

/**
 * Create initial state for a new project.
 *
 * @param {Object} config - parsed orchestration config
 * @param {string} projectDir - absolute path to project directory
 * @returns {Object} fresh v5 state object
 */
function scaffoldInitialState(config, projectDir) {
  const now = new Date().toISOString();
  return {
    $schema: SCHEMA_VERSION,   // 'orchestration-state-v5' (from staged constants.js)
    project: {
      name: path.basename(projectDir),
      created: now,
      updated: now,
    },
    pipeline: {
      current_tier: 'planning',
      gate_mode: null,
      source_control: {
        activation_choice: null,
        branch_from_choice: null,
        worktree_path: null,
        branch: null,
        cleanup_choice: null,
      },
    },
    planning: {
      status: 'not_started',
      human_approved: false,
      steps: [
        { name: 'research',      status: 'not_started', doc_path: null },
        { name: 'prd',           status: 'not_started', doc_path: null },
        { name: 'design',        status: 'not_started', doc_path: null },
        { name: 'architecture',  status: 'not_started', doc_path: null },
        { name: 'master_plan',   status: 'not_started', doc_path: null },
      ],
    },
    execution: {
      status: 'not_started',
      current_phase: 0,
      phases: [],
    },
    final_review: {
      status: 'not_started',
      doc_path: null,
      human_approved: false,
    },
  };
}

// ─── handleInit ─────────────────────────────────────────────────────────────

function handleInit(config, projectDir, io) {
  // Version check: verify config version is valid before scaffolding
  // Use a temporary scaffold to extract $schema for comparison
  const tempState = { $schema: SCHEMA_VERSION };
  const compat = checkVersionCompatibility(config, tempState);
  if (!compat.compatible) {
    return {
      success: false,
      action: null,
      context: {
        error: `Version mismatch: config is v${compat.configVersion}, state is v${compat.stateVersion}`,
        detail: 'Run: node .github/skills/orchestration/scripts/migrate-to-v5.js --config <path-to-orchestration.yml>',
      },
      mutations_applied: [],
    };
  }

  io.ensureDirectories(projectDir);
  const initialState = scaffoldInitialState(config, projectDir);
  io.writeState(projectDir, initialState);
  const next = resolveNextAction(initialState, config);
  return {
    success: true,
    action: next.action,
    context: next.context,
    mutations_applied: ['project_initialized'],
  };
}

// ─── handleColdStart ────────────────────────────────────────────────────────

function handleColdStart(currentState, config) {
  const compat = checkVersionCompatibility(config, currentState);
  if (!compat.compatible) {
    return {
      success: false,
      action: null,
      context: {
        error: `Version mismatch: config is v${compat.configVersion}, state is v${compat.stateVersion}`,
        detail: 'Run: node .github/skills/orchestration/scripts/migrate-to-v5.js <project-dir>',
      },
      mutations_applied: [],
    };
  }
  const next = resolveNextAction(currentState, config);
  return { success: true, action: next.action, context: next.context, mutations_applied: [] };
}

// ─── processEvent ───────────────────────────────────────────────────────────

/**
 * Process a single pipeline event. Implements the linear recipe:
 * load → pre-read → mutate → validate → write → resolve → return.
 *
 * @param {string} event - pipeline event name
 * @param {string} projectDir - absolute path to project directory
 * @param {Object} context - event-specific context from Orchestrator
 * @param {Object} io - dependency-injected I/O
 * @param {string} [configPath] - path to orchestration.yml; auto-discovers if omitted
 * @returns {Object} PipelineResult
 */
function processEvent(event, projectDir, context, io, configPath) {
  const config = io.readConfig(configPath);
  const currentState = io.readState(projectDir);

  // Init path: no state + start event
  if (!currentState && event === 'start') {
    return handleInit(config, projectDir, io);
  }

  // Cold-start path: existing state + start event
  if (currentState && event === 'start') {
    return handleColdStart(currentState, config);
  }

  // No state + non-start event
  if (!currentState) {
    return {
      success: false,
      action: null,
      context: { error: 'No state.json found; use --event start to initialize' },
      mutations_applied: [],
    };
  }

  // ── Standard path ─────────────────────────────────────────────────────

  const preReadResult = preRead(event, context, io.readDocument, projectDir);
  if (preReadResult.error) {
    return {
      success: false,
      action: null,
      context: preReadResult.error,
      mutations_applied: [],
    };
  }

  const mutationFn = getMutation(event);
  if (!mutationFn) {
    return {
      success: false,
      action: null,
      context: { error: `Unknown event: ${event}` },
      mutations_applied: [],
    };
  }

  // ── Single-point doc_path normalization ──────────────────────────────
  const normalizedContext = { ...preReadResult.context };
  if (normalizedContext.doc_path) {
    normalizedContext.doc_path = normalizeDocPath(
      normalizedContext.doc_path,
      config.projects.base_path,
      path.basename(projectDir)
    );
  }

  const proposed = mutationFn(deepClone(currentState), normalizedContext, config);

  // ensure project.updated strictly advances before validation
  const now = new Date().toISOString();
  const prev = currentState.project.updated;
  proposed.state.project.updated = (prev && now <= prev)
    ? new Date(new Date(prev).getTime() + 1).toISOString()
    : now;

  const errors = validateTransition(currentState, proposed.state, config);
  if (errors.length > 0) {
    return {
      success: false,
      action: null,
      context: { error: 'State validation failed', violations: errors },
      mutations_applied: [],
    };
  }

  io.writeState(projectDir, proposed.state);

  const next = resolveNextAction(proposed.state, config);

  return {
    success: true,
    action: next.action,
    context: next.context,
    mutations_applied: proposed.mutations_applied,
  };
}

// ─── Exports ────────────────────────────────────────────────────────────────

module.exports = {
  processEvent,
  scaffoldInitialState,
  extractConfigMajor,
  extractStateMajor,
  checkVersionCompatibility,
};

