node_modules/
package-lock.json
# CI's `npm ci` for the cli subpackage needs a committed lockfile
!cli/package-lock.json
# Engine needs a committed lockfile for dependency repeatability
!greenfield/harness-adapters/engine/package-lock.json

.vscode/mcp.json

.vscode/settings.json

# User-owned Claude Code settings — never committed. Personal hooks, settings
# overrides, and scheduled-task locks go here; the dogfood build no longer writes
# under .claude/ at the repo root (it deploys to ~/.claude/ via the installer's
# manifest-driven library — see scripts/build.js).
.claude/settings.json
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Adapter staging hopper + dogfood prior-manifest cache + esbuild scratch.
# scripts/build.js writes dist/staging/<harness>/ (transformed adapter output)
# and dist/dogfood-prior-<harness>.json (prior-manifest snapshot used to clean
# up renamed/deleted rad files on the next build). Never committed.
/dist/

# esbuild bundle output — produced by `npm run bundle` in cli/ and harness-files/skills/rad-orchestration/scripts/
dist-bundle/

# Ephemeral installer test directory — created by rad-test-release prompt, never committed
test-installer/

*.code-workspace

# Ephemeral test log artifacts — never commit
*-tests.log

# Prompt harness — run outputs ignored by default.
# NOTE: git ignore cannot re-include files if an ancestor directory is excluded
# by a directory-matching pattern. The rules below ignore run-folder CONTENTS
# (files at least two levels under output/) while leaving the fixture-specific
# directory (`output/<fixture>/`) un-ignored, so `!` exceptions below can
# re-include specific files under otherwise-ignored run folders.
/prompt-tests/extra-high-pipeline-e2e/output/*/*/**
!/prompt-tests/extra-high-pipeline-e2e/output/*/.gitkeep
!/prompt-tests/extra-high-pipeline-e2e/output/rainbow-hello/baseline-*/lint-report.md
!/prompt-tests/extra-high-pipeline-e2e/output/rainbow-hello/baseline-*/run-notes.md
!/prompt-tests/extra-high-pipeline-e2e/output/rainbow-hello/baseline-rainbow-hello-2026-05-01/lint-report.md
!/prompt-tests/extra-high-pipeline-e2e/output/rainbow-hello/baseline-rainbow-hello-2026-05-01/run-notes.md

# Prompt harness — corrective-mediation-e2e.
# Same structure as plan-pipeline-e2e: ignore run-folder contents, re-include
# the inaugural-baseline run-notes.md under baseline-* folders.
/prompt-tests/corrective-mediation-e2e/output/*/*/**
!/prompt-tests/corrective-mediation-e2e/output/*/.gitkeep
!/prompt-tests/corrective-mediation-e2e/output/broken-colors/baseline-*/run-notes.md

# Prompt harness — phase-review-mediation-e2e.
# Same structure as above: ignore run-folder contents, re-include the
# inaugural-baseline run-notes.md under baseline-* folders.
/prompt-tests/phase-review-mediation-e2e/output/*/*/**
!/prompt-tests/phase-review-mediation-e2e/output/*/.gitkeep
!/prompt-tests/phase-review-mediation-e2e/output/colors-greet-mismatch/baseline-*/run-notes.md

# Prompt harness — code-review-rework-e2e (iter-12).
