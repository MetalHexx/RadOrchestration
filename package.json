{
  "name": "rad-orchestration-monorepo",
  "private": true,
  "workspaces": [
    "lib/repo-registry",
    "lib/work-graph",
    "cli",
    "ui",
    "harness-adapters/engine",
    "harness-installers/shared/build-helpers",
    "harness-installers/standard",
    "harness-installers/claude-plugin",
    "harness-installers/copilot-cli-plugin",
    "harness-installers/copilot-vscode-plugin"
  ],
  "type": "module",
  "description": "Repo-root build scripts for the multi-harness adapter build loop.",
  "scripts": {
    "build": "node harness-dogfood/build.js",
    "build:claude": "node harness-dogfood/build.js --harness=claude",
    "build:copilot-vscode": "node harness-dogfood/build.js --harness=copilot-vscode",
    "build:copilot-cli": "node harness-dogfood/build.js --harness=copilot-cli",
    "build:all": "node harness-dogfood/build.js --all"
  }
}
