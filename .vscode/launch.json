{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug UI",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/ui/node_modules/next/dist/bin/next",
      "args": ["dev"],
      "runtimeArgs": ["--inspect"],
      "cwd": "${workspaceFolder}/ui",
      "console": "integratedTerminal",
      "preLaunchTask": "Kill port 9229",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/ui"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
