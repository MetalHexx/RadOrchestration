{
  "name": "@rad-orchestration/repo-registry",
  "version": "1.0.0-alpha.9",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "description": "Typed two-file read/write registry for repos and repo-groups",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": { "js-yaml": "^4.1.0" },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
