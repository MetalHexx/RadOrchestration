# Built plugin payload — emitted fresh by build-scripts/build.js on every
# invocation. The folder is the publishable tarball staging area; it must
# never enter git so contributors never accidentally commit build artifacts.
output/
node_modules/

# Ephemeral dogfood marketplace tree — created by rad-test-copilot-cli-plugin
# for local copilot plugin install testing. Same gitignore posture the
# claude-plugin sibling takes.
dogfood-marketplace/

# Ephemeral expand-tokens staging dir — created by build-scripts/build.js
# inside the installer dir; deleted on success, but can persist if the
# expand-tokens step throws mid-run.
.expand-staging/
