{
  "name": "@radorch/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "radorch CLI — greenfield TypeScript package (iteration 1, local-only)",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "radorch": "./dist/bin/radorch.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.0",
    "commander": "^14.0.0",
    "figlet": "^1.11.0",
    "js-yaml": "^4.1.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
