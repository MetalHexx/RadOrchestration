{
  "name": "@rad-orchestration/cli",
  "version": "1.0.0-alpha.9",
  "private": true,
  "type": "module",
  "description": "radorch CLI — global orchestration root manager",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "radorch": "./dist/cli/src/bin/radorch.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node dist/cli/src/bin/radorch.js",
    "build-and-start": "tsc && node dist/cli/src/bin/radorch.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.0",
    "commander": "^14.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
